+class _AirPodsIcon extends StatelessWidget {
+  final Color color;
+  final double size;
+
+  const _AirPodsIcon({required this.color, required this.size});
+
+  @override
+  Widget build(BuildContext context) {
+    return SizedBox(
+      width: size,
+      height: size,
+      child: CustomPaint(painter: _AirPodsPainter(color)),
+    );
