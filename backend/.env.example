# Puerto del backend
PORT=10000

# Clave opcional para proteger endpoints
RESOLVER_API_KEY=

# CORS (opcional): lista separada por coma
# Ejemplo: CORS_ALLOW_ORIGINS=https://tuapp.com,https://admin.tuapp.com
CORS_ALLOW_ORIGINS=

# Resolver YouTube (solo youtube_explode_dart)
DART_BINARY=dart
YTEXPLODE_DART_TIMEOUT_MS=30000
# Cookie autenticada para youtube_explode_dart (formato header: name=value; name2=value2)
YTEXPLODE_COOKIE=
# Alternativa en base64 para entornos que no soportan bien ';' en variables.
YTEXPLODE_COOKIE_B64=
RESOLVE_CACHE_TTL_MS=30000
RESOLVE_BATCH_LIMIT=20

# Stems (Demucs)
STEMS_ROOT=/tmp/vmmusic-stems
STEMS_MODEL=htdemucs_ft
STEMS_PYTHON=python3
STEMS_TIMEOUT_MS=720000
STEMS_CACHE_TTL_MS=30000

# Proxy para animar carátulas (opcional)
COVER_ANIMATION_PROXY_URL=
COVER_ANIMATION_PROXY_KEY=
COVER_ANIMATION_TIMEOUT_MS=90000
